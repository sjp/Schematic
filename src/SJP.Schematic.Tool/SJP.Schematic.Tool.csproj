<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>schematic</AssemblyName>
    <Description>Tool for accessing and running Schematic functionality</Description>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <PackageId>dotnet-schematic</PackageId>
    <!-- Both the standalone executable (AssemblyName) and the installed .NET tool
         are invoked as 'schematic', which is also the name the shell completion
         scripts register against. -->
    <ToolCommandName>schematic</ToolCommandName>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- AssemblyName is 'schematic', so the default InternalsVisibleTo convention
       (see Directory.Build.targets) would target 'schematic.Tests'. Point it at the
       actual test assembly instead so its natural name can be kept. -->
  <ItemGroup>
    <InternalsVisibleTo Include="SJP.Schematic.Tool.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Spectre.Console.Analyzer">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Spectre.Console.Cli" />
    <PackageReference Include="Spectre.Console.Cli.Extensions.DependencyInjection" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SJP.Schematic.DataAccess.EntityFrameworkCore\SJP.Schematic.DataAccess.EntityFrameworkCore.csproj" />
    <ProjectReference Include="..\SJP.Schematic.DataAccess.OrmLite\SJP.Schematic.DataAccess.OrmLite.csproj" />
    <ProjectReference Include="..\SJP.Schematic.DataAccess.Poco\SJP.Schematic.DataAccess.Poco.csproj" />
    <ProjectReference Include="..\SJP.Schematic.MySql\SJP.Schematic.MySql.csproj" />
    <ProjectReference Include="..\SJP.Schematic.Oracle\SJP.Schematic.Oracle.csproj" />
    <ProjectReference Include="..\SJP.Schematic.PostgreSql\SJP.Schematic.PostgreSql.csproj" />
    <ProjectReference Include="..\SJP.Schematic.Reporting\SJP.Schematic.Reporting.csproj" />
    <ProjectReference Include="..\SJP.Schematic.Sqlite\SJP.Schematic.Sqlite.csproj" />
    <ProjectReference Include="..\SJP.Schematic.SqlServer\SJP.Schematic.SqlServer.csproj" />
  </ItemGroup>

</Project>
