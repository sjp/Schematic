<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>SQLite database metadata provider for Schematic</Description>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SQLite" />
    <!-- Pin the SQLitePCLRaw stack to a patched build; the version brought in transitively
         by Microsoft.Data.SQLite has a known native SQLite vulnerability (GHSA-2m69-gcr7-jv3q). -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" />
    <PackageReference Include="Superpower" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SJP.Schematic.Core\SJP.Schematic.Core.csproj" />
  </ItemGroup>

</Project>